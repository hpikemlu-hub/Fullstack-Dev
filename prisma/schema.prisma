// Unified Fullstack Database Schema
// Migration from Supabase to PostgreSQL with Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String   @id @default(cuid())
  namaLengkap String   @map("nama_lengkap")
  nip         String?  @unique
  golongan    String?
  jabatan     String?
  username    String   @unique
  email       String?  @unique
  password    String   // bcrypt hashed password
  role        String   @default("USER")  // Changed from enum to String
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  workloads       Workload[]
  calendarEvents  CalendarEvent[]
  auditLogs       AuditLog[]
  createdEKinerja EKinerja[]
  refreshTokens   RefreshToken[]
  
  @@map("users")
}

model Workload {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  nama        String
  type        String
  deskripsi   String?
  status      String @default("PENDING")  // Changed from enum to String
  tglDiterima DateTime?      @map("tgl_diterima")
  tglDeadline DateTime?      @map("tgl_deadline") // New field for deadlines
  fungsi      String?
  priority    String       @default("MEDIUM") // Changed from enum to String
  estimatedHours Int?         @map("estimated_hours") // New field for estimation
  actualHours    Int?         @map("actual_hours") // New field for tracking
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([tglDiterima])
  @@index([tglDeadline])
  @@map("workload")
}

model CalendarEvent {
  id           String    @id @default(cuid())
  creatorId    String    @map("creator_id")
  title        String
  description  String?
  participants String?  // JSON string of participant names/emails
  location     String?
  dipa         String?
  startDate    DateTime  @map("start_date")
  endDate      DateTime  @map("end_date")
  color        String    @default("#0d6efd")
  isCompleted  Boolean   @default(false) @map("is_completed") // Auto-completion status
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  
  // Relations
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  // Constraints
  @@index([creatorId])
  @@index([startDate, endDate])
  @@index([isCompleted])
  @@map("calendar_events")
}

model AuditLog {
  id         String    @id @default(cuid())
  userId     String?   @map("user_id")
  userName   String    @map("user_name")
  action     String    // CREATE, UPDATE, DELETE
  tableName  String    @map("table_name")
  recordId   String?   @map("record_id")
  oldValues  String?     @map("old_values")
  newValues  String?     @map("new_values")
  details    String?
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at")
  
  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Indexes
  @@index([userId])
  @@index([action])
  @@index([tableName])
  @@index([createdAt])
  @@map("audit_log")
}

model EKinerja {
  id          String    @id @default(cuid())
  tglSurat    DateTime? @map("tgl_surat")
  noSurat     String?   @map("no_surat")
  perihal     String?
  kepada      String?
  jenisSurat  String?   @map("jenis_surat")
  tujuan      String?
  urlDokumen  String?   @map("url_dokumen")
  filePath    String?   @map("file_path")
  fileSize    Int?      @map("file_size") // File size in bytes
  mimeType    String?   @map("mime_type") // File MIME type
  createdById String?   @map("created_by") 
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  
  // Indexes
  @@index([tglSurat])
  @@index([jenisSurat])
  @@index([createdById])
  @@map("e_kinerja")
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@map("settings")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id") 
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// Enums converted to constants for SQLite compatibility
// Role: ADMIN, USER
// WorkloadStatus: DONE, ON_PROGRESS, PENDING  
// Priority: LOW, MEDIUM, HIGH, URGENT

