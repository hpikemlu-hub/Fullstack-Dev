# 🔧 Environment Variables Template for Coolify Deployment
# Copy this file to .env.local for local development
# Configure these variables in Coolify dashboard for production

# ===== REQUIRED FOR PRODUCTION =====
NODE_ENV=production
PORT=3000

# JWT Authentication (REQUIRED - Generate secure 32+ character strings)
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters-long
JWT_REFRESH_SECRET=your-secure-refresh-secret-minimum-32-characters-long

# Application URL (Update with your Coolify domain)
NEXT_PUBLIC_BASE_URL=https://your-app.coolify.domain.com

# ===== DATABASE OPTIONS =====

# Option 1: SQLite (Simple - Default for initial deployment)
DATABASE_URL=file:./production.db

# Option 2: PostgreSQL (Recommended for production scaling)
# DATABASE_URL=postgresql://username:password@postgres-host:5432/database_name

# Option 3: Supabase (if migrating back)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== OPTIONAL ENHANCEMENTS =====

# Redis for caching and sessions
# REDIS_URL=redis://redis-host:6379

# Email configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-app@domain.com

# File storage
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10485760

# Security
# CORS_ORIGIN=https://your-frontend-domain.com
# CSRF_SECRET=your-csrf-secret-32-chars
# SESSION_SECRET=your-session-secret-32-chars

# Analytics & Monitoring
# SENTRY_DSN=https://your-sentry-dsn
# GOOGLE_ANALYTICS_ID=GA-XXXXX-X
# POSTHOG_KEY=phc_xxxxx

# Feature Flags
# ENABLE_REGISTRATION=false
# ENABLE_EMAIL_VERIFICATION=false
# ENABLE_2FA=false

# Development Only (DO NOT SET IN PRODUCTION)
# DEBUG=true
# VERBOSE_LOGGING=true