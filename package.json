{
  "name": "workload-management-fullstack",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "migrate:supabase": "tsx scripts/migrate-supabase.ts",
    "setup:dev": "bash scripts/setup-dev.sh",
    "docker:dev": "docker-compose -f docker/docker-compose.dev.yml up -d",
    "docker:dev:full": "docker-compose -f docker/docker-compose.dev.yml up -d --build",
    "docker:dev:services": "docker-compose -f docker/docker-compose.dev.yml up -d postgres redis adminer",
    "docker:dev:stop": "docker-compose -f docker/docker-compose.dev.yml down",
    "docker:dev:clean": "docker-compose -f docker/docker-compose.dev.yml down -v --rmi local",
    "docker:prod": "docker-compose -f docker/docker-compose.prod.yml up -d",
    "docker:build": "docker build -f docker/Dockerfile -t workload-app .",
    "docker:build:prod": "docker build --target runner -f docker/Dockerfile -t workload-app:latest .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:integration": "tsx scripts/test-integration.ts",
    "test:db": "tsx scripts/test-database-connection.ts",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:visual": "playwright test tests/visual-regression/",
    "test:performance": "playwright test tests/performance/",
    "test:migration": "jest --testPathPattern=tests/migration",
    "test:all": "npm run test && npm run test:e2e && npm run test:migration",
    "test:ci": "npm run test -- --coverage --watchAll=false && npm run test:e2e",
    "type-check": "tsc --noEmit",
    "health-check": "tsx scripts/health-check.ts",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:prod": "bash scripts/deploy-production.sh",
    "backup:db": "tsx scripts/backup-database.ts",
    "monitor:logs": "docker-compose -f docker/docker-compose.dev.yml logs -f",
    "monitor:performance": "tsx scripts/performance-check.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.20.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^2.30.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.555.0",
    "multer": "^1.4.5-lts.1",
    "next": "16.0.5",
    "prisma": "^5.20.0",
    "react": "19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "recharts": "^3.5.1",
    "redis": "^5.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.18.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19",
    "@types/ws": "^8.5.13",
    "autoprefixer": "^10.4.22",
    "eslint": "^9",
    "eslint-config-next": "16.0.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-test-api-route-handler": "^4.0.8",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
