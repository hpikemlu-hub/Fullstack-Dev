# Environment Configuration Template
# Copy this to .env.local and fill in your values

# ====================================
# DATABASE CONFIGURATION
# ====================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workload_dev"

# ====================================
# REDIS CONFIGURATION (OPTIONAL)
# ====================================
# REDIS_URL="redis://localhost:6379"  # Disabled for development

# ====================================
# JWT AUTHENTICATION
# ====================================
# Generate secure random keys for production
# You can use: openssl rand -hex 32
JWT_SECRET="dev_jwt_secret_change_in_production"
JWT_REFRESH_SECRET="dev_refresh_secret_change_in_production"

# ====================================
# APPLICATION CONFIGURATION
# ====================================
NODE_ENV="development"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"
UPLOAD_PATH="./uploads"

# ====================================
# DEVELOPMENT TOOLS
# ====================================
# Enable development features
NEXT_TELEMETRY_DISABLED="1"
DEBUG="false"

# ====================================
# MONITORING & LOGGING
# ====================================
# Application monitoring
ENABLE_METRICS="true"
LOG_LEVEL="info"

# Health check configuration
HEALTH_CHECK_TIMEOUT="5000"

# ====================================
# BACKUP CONFIGURATION
# ====================================
BACKUP_RETENTION_DAYS="30"
BACKUP_COMPRESSION="true"

# ====================================
# SUPABASE MIGRATION (TEMPORARY)
# ====================================
# These are used only for the one-time migration from Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# ====================================
# PRODUCTION ENVIRONMENT VARIABLES
# ====================================
# For production deployment on Coolify

# Database (managed by Coolify)
# DATABASE_URL will be automatically set by Coolify PostgreSQL service

# Security
# JWT_SECRET="production_jwt_secret_32_chars_minimum"
# JWT_REFRESH_SECRET="production_refresh_secret_32_chars_minimum"

# Application
# ALLOWED_ORIGINS="https://yourdomain.com"
# UPLOAD_PATH="/app/uploads"

# Optional Services
# REDIS_URL="redis://redis:6379"  # If using Redis service in Coolify

# ====================================
# CI/CD & DEPLOYMENT
# ====================================
# Coolify webhook URLs for deployment
# COOLIFY_STAGING_WEBHOOK="https://coolify.example.com/webhooks/staging"
# COOLIFY_PRODUCTION_WEBHOOK="https://coolify.example.com/webhooks/production"

# Notification webhooks
# SLACK_WEBHOOK="https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK"
# EMAIL_WEBHOOK="https://api.example.com/send-email"

# Deployment URLs
# STAGING_URL="https://staging.workload.example.com"
# PRODUCTION_URL="https://workload.kemlu.go.id"

# ====================================
# DOCKER COMPOSE VARIABLES
# ====================================
# Used by docker-compose.prod.yml
POSTGRES_DB="workload_production"
POSTGRES_USER="workload_user"
POSTGRES_PASSWORD="secure_password_here"